# Copy once: cp openwrt-metrics.env.example /etc/openwrt-metrics.env
# Edit /etc/openwrt-metrics.env — setup_metrics.sh will NOT overwrite it.

PUBLISH_METHOD="mqtt"

MQTT_BROKER="192.168.1.1"
MQTT_PORT="1883"
MQTT_USER="your_mqtt_user"
MQTT_PASSWORD="your_mqtt_password"

# HTTP method only (PUBLISH_METHOD="http"):
HA_URL="http://homeassistant.local"
HA_PORT="8123"
HA_TOKEN="your_long_lived_token"

MQTT_TOPIC_PREFIX="openwrt"
ENABLE_NLBW="true"
